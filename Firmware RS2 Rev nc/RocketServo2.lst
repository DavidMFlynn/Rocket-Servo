00398 0000      M	;
00399 0000      M	;==============================================================================================
00400 0000      M	; EEPROM locations (NV-RAM) 0x00..0x7F (offsets)
00401 0000      M		org	0xF000
00402 F000      M	; Servo 1 initial values
00403 F000 0010      M		de	LOW kDefaultPosition1	;nvPosition1Lo
00404 F001 000E      M		de	HIGH kDefaultPosition1
00405 F002 0098      M		de	LOW kDefaultPosition2
00406 F003 0008      M		de	HIGH kDefaultPosition2
00407 F004      M	; Servo 2 initial values
00408 F004 0010      M		de	LOW kDefaultPosition1	;nvPosition1Lo
00409 F005 000E      M		de	HIGH kDefaultPosition1
00410 F006 0098      M		de	LOW kDefaultPosition2
00411 F007 0008      M		de	HIGH kDefaultPosition2
00412 F008      M	;
00413 F008 0022      M		de	kInPosShutdown	;nvSysFlags
00414 F009      M	;
00415 F009      M		cblock	0x00
00416 F009 0000 M		nvPosition1Lo
00417 F009 0001 M		nvPosition1Hi
00418 F009 0002 M		nvPosition2Lo
00419 F009 0003 M		nvPosition2Hi
00420 F009 0004 M		nvPosition3Lo
00421 F009 0005 M		nvPosition3Hi
00422 F009 0006 M		nvPosition4Lo
00423 F009 0007 M		nvPosition4Hi
