00252 0000 004C M		S2Position1:2		;Servo2 rest
00253 0000 004E M		S2Position2:2		;Servo2 Triggered
00254 0000 0050 M		SysFlags
00255 0000      M	;
00256 0000 0051 M		S1CmdDebounce
00257 0000 0052 M		S2CmdDebounce
00258 0000      M	;
00259 0000      M		endc
