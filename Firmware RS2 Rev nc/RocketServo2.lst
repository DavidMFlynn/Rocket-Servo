00406 F001 000E      M		de	HIGH kDefaultPosition1
00407 F002 0098      M		de	LOW kDefaultPosition2
00408 F003 0008      M		de	HIGH kDefaultPosition2
00409 F004      M	; Servo 2 initial values
00410 F004 0010      M		de	LOW kDefaultPosition1	;nvPosition1Lo
00411 F005 000E      M		de	HIGH kDefaultPosition1
00412 F006 0098      M		de	LOW kDefaultPosition2
00413 F007 0008      M		de	HIGH kDefaultPosition2
00414 F008      M	;
00415 F008 0022      M		de	kInPosShutdown	;nvSysFlags
00416 F009      M	;
00417 F009      M		cblock	0x00
00418 F009 0000 M		nvPosition1Lo
00419 F009 0001 M		nvPosition1Hi
00420 F009 0002 M		nvPosition2Lo
00421 F009 0003 M		nvPosition2Hi
00422 F009 0004 M		nvPosition3Lo
00423 F009 0005 M		nvPosition3Hi
00424 F009 0006 M		nvPosition4Lo
