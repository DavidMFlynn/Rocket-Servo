00223 0000 002F M		EEDataTemp		;Data to be writen to EEProm
00224 0000      M	;
00225 0000      M	;
00226 0000 0030 M		Timer1Lo		;1st 16 bit timer
00227 0000 0031 M		Timer1Hi		; 1 sec delay, local loop
00228 0000 0032 M		Timer2Lo		;2nd 16 bit timer
00229 0000 0033 M		Timer2Hi		; Servo 1 active timer
00230 0000 0034 M		Timer3Lo		;3rd 16 bit timer
00231 0000 0035 M		Timer3Hi		; Servo 1 Activation timer
00232 0000 0036 M		Timer4Lo		;4th 16 bit timer
00233 0000 0037 M		Timer4Hi		; debounce timer and power up delay timer
00234 0000 0038 M		Timer5Lo		;5th 16 bit timer
00235 0000 0039 M		Timer5Hi		; Servo 2 active timer
00236 0000 003A M		Timer6Lo		;6th 16 bit timer
00237 0000 003B M		Timer6Hi		; Servo 2 Activation timer
00238 0000      M	;
00239 0000 003C M		State		;State 0..n, Startup LED sequence and main state
00240 0000 003D M		State2		;State 0..n, Servo current testing
00241 0000      M	;
