00431 F009 0008 M	#Define	nvLastParamByte	nvSysFlags
00432 F009      M	;
00433 F009      M	;
00434 F009      M	;==============================================================================================
00435 F009      M	;============================================================================================
00436 F009      M	;
00437 F009      M	;
00438 F009      M		ORG	0x000	; processor reset vector
00439 0000 0183      M		CLRF	STATUS
00440 0001 018A      M		CLRF	PCLATH
00441 0002 28B8      M	  	goto	start	; go to beginning of program
00442 0003      M	;
00443 0003      M	;===============================================================================================
00444 0003      M	; Interupt Service Routine
00445 0003      M	;
00446 0003      M	; we loop through the interupt service routing every 0.01 seconds
00447 0003      M	;
00448 0003      M	;
00449 0003      M		ORG	0x004	; interrupt vector location
00450 0004 018A      M		CLRF	PCLATH
00451 0005 0020      M		movlb	0	; bank0
