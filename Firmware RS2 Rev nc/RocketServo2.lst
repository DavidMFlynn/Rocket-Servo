00196 0000 	;================================================================================================
00197 0000 	;***** VARIABLE DEFINITIONS
00198 0000 	; there are 1024 bytes of ram, Bank0 0x20..0x7F, Bank1 0xA0..0xEF, ....
00199 0000 	; there are 256 bytes of EEPROM starting at 0x00 the EEPROM is not mapped into memory but
00200 0000 	;  accessed through the EEADR and EEDATA registers
00201 0000 	;================================================================================================
00202 0000 	;  Bank0 Ram 020h-06Fh 80 Bytes
00203 0000 	;
