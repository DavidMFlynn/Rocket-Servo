00427 F009      M	;
00428 F009 0000 M	#Define	nvFirstParamByte	nvPosition1Lo
00429 F009 0008 M	#Define	nvLastParamByte	nvSysFlags
00430 F009      M	;
00431 F009      M	;
00432 F009      M	;==============================================================================================
00433 F009      M	;============================================================================================
00434 F009      M	;
00435 F009      M	;
00436 F009      M		ORG	0x000	; processor reset vector
00437 0000 0183      M		CLRF	STATUS
00438 0001 018A      M		CLRF	PCLATH
00439 0002 28B8      M	  	goto	start	; go to beginning of program
00440 0003      M	;
00441 0003      M	;===============================================================================================
00442 0003      M	; Interupt Service Routine
00443 0003      M	;
00444 0003      M	; we loop through the interupt service routing every 0.01 seconds
00445 0003      M	;
00446 0003      M	;
00447 0003      M		ORG	0x004	; interrupt vector location
00448 0004 018A      M		CLRF	PCLATH
00449 0005 0020      M		movlb	0	; bank0
00450 0006      M	;
00451 0006 1C91      M		btfss	PIR1,TMR2IF
00452 0007 2858      M		goto	IRQ_2
00453 0008 1091      M		bcf	PIR1,TMR2IF	; reset interupt flag bit
